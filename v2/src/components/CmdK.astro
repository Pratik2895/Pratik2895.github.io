---
// Linear/Raycast-style command palette. Opens on Ctrl/Cmd+K.
---
<div id="cmdk-root" class="fixed inset-0 z-[80] hidden items-start justify-center pt-[12vh] px-4" role="dialog" aria-modal="true" aria-label="Command palette">
  <!-- backdrop -->
  <div id="cmdk-backdrop" class="absolute inset-0 bg-ink-950/70 backdrop-blur-md"></div>

  <!-- panel -->
  <div class="relative w-full max-w-lg rounded-xl border border-ink-800 bg-ink-900/95 backdrop-blur-xl shadow-2xl overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(600px circle at 50% 0%, rgba(57,239,255,0.08), transparent 50%);"></div>

    <div class="relative">
      <!-- Search -->
      <div class="flex items-center gap-3 px-4 py-3 border-b border-ink-800">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-ink-400 flex-shrink-0">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          id="cmdk-input"
          type="text"
          placeholder="Type to search — try 'projects', 'resume', 'email'…"
          class="flex-1 bg-transparent outline-none text-sm text-ink-100 placeholder-ink-500"
          autocomplete="off"
          spellcheck="false"
        />
        <kbd class="hidden sm:inline-flex items-center gap-1 text-[10px] font-mono px-1.5 py-0.5 rounded bg-ink-800 text-ink-400 border border-ink-700">
          ESC
        </kbd>
      </div>

      <!-- Results -->
      <div id="cmdk-list" class="max-h-[60vh] overflow-y-auto p-2"></div>

      <!-- Footer hints -->
      <div class="flex items-center justify-between px-4 py-2 border-t border-ink-800 text-[10px] font-mono text-ink-500">
        <div class="flex items-center gap-3">
          <span class="flex items-center gap-1"><kbd class="px-1 py-0.5 rounded bg-ink-800 border border-ink-700">↑↓</kbd>navigate</span>
          <span class="flex items-center gap-1"><kbd class="px-1 py-0.5 rounded bg-ink-800 border border-ink-700">↵</kbd>select</span>
        </div>
        <span class="text-brand">pratik.dev</span>
      </div>
    </div>
  </div>
</div>

<!-- Floating hint badge (bottom-right) -->
<button
  id="cmdk-hint"
  type="button"
  class="fixed bottom-4 right-4 z-[70] inline-flex items-center gap-2 px-3 py-2 rounded-full border border-ink-800 bg-ink-900/80 backdrop-blur-md text-xs text-ink-300 hover:border-brand hover:text-brand transition-colors shadow-lg"
  aria-label="Open command palette"
>
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
  <span class="hidden sm:inline">Search</span>
  <kbd class="font-mono text-[10px] px-1 py-0.5 rounded bg-ink-800 border border-ink-700">⌘K</kbd>
</button>

<script is:inline>
(function() {
  const root   = document.getElementById('cmdk-root');
  const input  = document.getElementById('cmdk-input');
  const list   = document.getElementById('cmdk-list');
  const hint   = document.getElementById('cmdk-hint');
  const backdrop = document.getElementById('cmdk-backdrop');
  if (!root || !input || !list) return;

  const COMMANDS = [
    { id: 'home',     title: 'Go to Home',        hint: 'H', href: '#home', icon: 'home', group: 'Navigate' },
    { id: 'about',    title: 'Go to About',       hint: '1', href: '#about', icon: 'user', group: 'Navigate' },
    { id: 'live',     title: 'Go to Live logs',   hint: 'L', href: '#live', icon: 'terminal', group: 'Navigate' },
    { id: 'exp',      title: 'Go to Experience',  hint: '2', href: '#experience', icon: 'briefcase', group: 'Navigate' },
    { id: 'projects', title: 'Go to Projects',    hint: '3', href: '#projects', icon: 'folder', group: 'Navigate' },
    { id: 'skills',   title: 'Go to Skills',      hint: '4', href: '#skills', icon: 'sparkles', group: 'Navigate' },
    { id: 'contact',  title: 'Go to Contact',     hint: '5', href: '#contact', icon: 'mail', group: 'Navigate' },

    { id: 'email',    title: 'Send email',                keywords: 'contact message write', href: 'mailto:bhikadi@uwindsor.ca', icon: 'mail', group: 'Contact' },
    { id: 'phone',    title: 'Call phone',                keywords: 'phone call',             href: 'tel:+16476751131',         icon: 'phone', group: 'Contact' },
    { id: 'resume',   title: 'Download resume (PDF)',     keywords: 'cv resume pdf download', href: '/PRATIK_A_BHIKADIYA_CV.pdf', target: '_blank', icon: 'file', group: 'Documents' },

    { id: 'github',   title: 'Open GitHub',           keywords: 'repos code',   href: 'https://github.com/Pratik2895',                target: '_blank', icon: 'code',     group: 'External' },
    { id: 'linkedin', title: 'Open LinkedIn',         keywords: 'profile network', href: 'https://www.linkedin.com/in/pratikbhikadiya/', target: '_blank', icon: 'linkedin', group: 'External' },

    { id: 'p-ontario', title: 'Project · Ontario Real Estate Lakehouse', keywords: 'medallion bronze silver gold', href: '/projects/ontario-real-estate/', icon: 'folder', group: 'Projects' },
    { id: 'p-stock',   title: 'Project · AI Stock Intelligence (RAG)',   keywords: 'ai rag gemini genai',          href: '/projects/ai-stock-intelligence/', icon: 'folder', group: 'Projects' },
    { id: 'p-f1',      title: 'Project · F1 Azure Databricks Lakehouse', keywords: 'azure adf unity catalog',       href: '/projects/f1-azure-databricks/',  icon: 'folder', group: 'Projects' },
    { id: 'p-mktg',    title: 'Project · Multi-Channel Marketing',       keywords: 'analytics engineering kpis',    href: '/projects/marketing-analytics/',  icon: 'folder', group: 'Projects' },
  ];

  const ICONS = {
    home:      '<path d="M3 12l2-2 7-7 7 7 2 2"/><path d="M9 21V12h6v9"/>',
    user:      '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',
    briefcase: '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>',
    folder:    '<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>',
    sparkles:  '<path d="M12 3v4M12 17v4M3 12h4M17 12h4"/><path d="M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8"/>',
    mail:      '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
    phone:     '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.89.31 1.76.57 2.6a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.84.26 1.71.45 2.6.57a2 2 0 0 1 1.72 2z"/>',
    file:      '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>',
    code:      '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
    linkedin:  '<path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.95v5.66H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.26 2.37 4.26 5.45zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.99 0 1.78-.78 1.78-1.73V1.73C24 .77 23.21 0 22.22 0z"/>',
    terminal:  '<polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>',
  };

  let active = 0;
  let filtered = COMMANDS;

  function score(item, q) {
    if (!q) return 1;
    const hay = (item.title + ' ' + (item.keywords || '')).toLowerCase();
    q = q.toLowerCase();
    if (hay.includes(q)) return 2;
    // Fuzzy: all chars present in order
    let i = 0;
    for (const ch of hay) { if (ch === q[i]) i++; if (i === q.length) return 1; }
    return 0;
  }

  function render() {
    const q = input.value.trim();
    filtered = COMMANDS.map((c) => ({ c, s: score(c, q) })).filter((x) => x.s > 0);
    filtered.sort((a, b) => b.s - a.s);
    filtered = filtered.map((x) => x.c);
    if (active >= filtered.length) active = 0;

    if (filtered.length === 0) {
      list.innerHTML = '<div class="px-4 py-10 text-center text-sm text-ink-500">No results</div>';
      return;
    }

    // Group by group field
    const groups = {};
    filtered.forEach((c) => { (groups[c.group] ??= []).push(c); });

    let html = '';
    let idx = 0;
    for (const [g, items] of Object.entries(groups)) {
      html += `<div class="px-2 pt-2 pb-1 text-[10px] uppercase tracking-wider text-ink-500 font-mono">${g}</div>`;
      for (const c of items) {
        const isActive = idx === active;
        html += `
          <button data-idx="${idx}" data-id="${c.id}"
            class="cmdk-item w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-left text-sm transition-colors
                   ${isActive ? 'bg-brand/10 text-white border border-brand/30' : 'text-ink-200 border border-transparent hover:bg-ink-800/70'}">
            <span class="w-7 h-7 rounded-md bg-ink-800 border border-ink-700 flex items-center justify-center text-ink-300 flex-shrink-0">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${ICONS[c.icon] || ''}</svg>
            </span>
            <span class="flex-1 truncate">${c.title}</span>
            ${c.hint ? `<kbd class="font-mono text-[9px] px-1 py-0.5 rounded bg-ink-800 text-ink-400 border border-ink-700">${c.hint}</kbd>` : ''}
          </button>`;
        idx++;
      }
    }
    list.innerHTML = html;
    const activeEl = list.querySelector(`[data-idx="${active}"]`);
    if (activeEl) activeEl.scrollIntoView({ block: 'nearest' });
  }

  function open() {
    root.classList.remove('hidden');
    root.classList.add('flex');
    document.body.style.overflow = 'hidden';
    input.value = '';
    active = 0;
    render();
    setTimeout(() => input.focus(), 10);
  }
  function close() {
    root.classList.add('hidden');
    root.classList.remove('flex');
    document.body.style.overflow = '';
  }
  function execute(cmd) {
    close();
    if (!cmd) return;
    if (cmd.href.startsWith('#')) {
      const t = document.querySelector(cmd.href) || document.querySelector(cmd.href + '-section');
      if (t) { t.scrollIntoView({ behavior: 'smooth' }); return; }
    }
    if (cmd.target === '_blank') {
      window.open(cmd.href, '_blank', 'noopener');
    } else {
      window.location.href = cmd.href;
    }
  }

  // Global hotkey
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      root.classList.contains('hidden') ? open() : close();
    } else if (e.key === 'Escape' && !root.classList.contains('hidden')) {
      close();
    }
  });

  // Within palette: arrows + enter
  input.addEventListener('input', () => { active = 0; render(); });
  input.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') { e.preventDefault(); active = Math.min(filtered.length - 1, active + 1); render(); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); active = Math.max(0, active - 1); render(); }
    else if (e.key === 'Enter') { e.preventDefault(); execute(filtered[active]); }
  });

  // Click on item
  list.addEventListener('click', (e) => {
    const btn = e.target.closest('.cmdk-item');
    if (!btn) return;
    const id = btn.getAttribute('data-id');
    execute(filtered.find((c) => c.id === id));
  });

  // Hint button opens palette
  hint.addEventListener('click', open);
  backdrop.addEventListener('click', close);
})();
</script>
