---
import { getCollection } from 'astro:content';
import ArchDiagram from './ArchDiagram.astro';

const all = await getCollection('projects');
const projects = all
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---
<section id="projects" class="section">
  <div class="container-custom">
    <div class="mb-14 flex flex-wrap items-end justify-between gap-4 reveal">
      <div>
        <p class="eyebrow">03 · Projects</p>
        <h2 class="section-title">Selected work</h2>
        <p class="text-ink-400 max-w-2xl">
          Real, end-to-end data products — each with its own architecture,
          metrics, and GitHub link. Hover a card to see the dataflow pulse.
        </p>
      </div>
      <a href="https://github.com/Pratik2895" target="_blank" rel="noopener" class="btn btn-ghost">
        All repos on GitHub
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((p) => (
        <a
          href={`/projects/${p.slug}/`}
          class={`accent-${p.data.accent} card-glow spotlight card-hover accent-border p-0 group flex flex-col overflow-hidden reveal`}
        >
          <!-- Architecture diagram strip -->
          <div class="relative h-28 bg-ink-950/60 border-b border-ink-800/60 px-4 py-3">
            <ArchDiagram variant={p.data.arch} />
            <div class="absolute top-2 right-3 flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 rounded-full bg-[color:var(--accent)] animate-pulse"></span>
              <span class="text-[9px] font-mono uppercase tracking-wider accent-text">{p.data.arch}</span>
            </div>
          </div>

          <div class="p-6 flex flex-col flex-1">
            <div class="flex items-start justify-between gap-3 mb-2">
              <h3 class="text-lg font-semibold text-white group-hover:text-[color:var(--accent)] transition-colors font-display tracking-tight">
                {p.data.title}
              </h3>
              <span class="font-mono text-xs text-ink-500 flex-shrink-0">
                /0{p.data.order}
              </span>
            </div>

            <p class="accent-text text-sm font-mono">{p.data.tagline}</p>

            <p class="mt-3 text-ink-300 text-sm leading-relaxed flex-1">
              {p.data.summary}
            </p>

            {p.data.metrics && (
              <div class="mt-5 grid grid-cols-3 gap-2">
                {p.data.metrics.slice(0, 3).map((m: { label: string; value: string }) => (
                  <div class="text-center py-2 px-1 rounded-md bg-ink-950/60 border border-ink-800/60">
                    <div class="text-xs font-bold text-white font-mono">{m.value}</div>
                    <div class="text-[9px] uppercase tracking-wider text-ink-500 mt-0.5 leading-tight">
                      {m.label}
                    </div>
                  </div>
                ))}
              </div>
            )}

            <div class="mt-5 flex flex-wrap gap-1.5">
              {p.data.stack.slice(0, 5).map((s: string) => <span class="chip">{s}</span>)}
            </div>

            <div class="mt-5 pt-4 border-t border-ink-800/60 flex items-center justify-between text-xs">
              <span class="text-ink-500 font-mono">{p.data.role}</span>
              <span class="accent-text group-hover:translate-x-1 transition-transform inline-flex items-center gap-1 font-mono">
                Case study
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
