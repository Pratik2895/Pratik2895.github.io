---
const cards = [
  { icon: 'loc',   label: 'Location', value: 'Brampton, ON, Canada' },
  { icon: 'mail',  label: 'Email',    value: 'bhikadi@uwindsor.ca', href: 'mailto:bhikadi@uwindsor.ca' },
  { icon: 'phone', label: 'Phone',    value: '+1 (647) 675-1131',   href: 'tel:+16476751131' },
  { icon: 'file',  label: 'Resume',   value: 'Download PDF',        href: '/PRATIK_A_BHIKADIYA_CV.pdf' },
];
---
<section id="contact" class="section relative">
  <div class="container-custom">
    <div class="relative overflow-hidden rounded-3xl border border-ink-800/80 bg-ink-900/40 backdrop-blur-md p-8 sm:p-14 reveal">
      <!-- Animated gradient corners -->
      <div class="absolute -top-24 -left-24 w-72 h-72 rounded-full bg-brand/20 blur-3xl"></div>
      <div class="absolute -bottom-24 -right-24 w-80 h-80 rounded-full bg-purple-500/20 blur-3xl"></div>
      <div class="absolute inset-0 pointer-events-none opacity-50" style="background: radial-gradient(600px circle at 50% 0%, rgba(57, 239, 255, 0.1), transparent 50%);"></div>

      <div class="relative text-center mb-10">
        <p class="eyebrow justify-center">05 · Contact</p>
        <h2 class="section-title">Let's build something</h2>
        <p class="text-ink-300 max-w-xl mx-auto">
          Open to Data Engineering / Analytics Engineering opportunities,
          consulting, and interesting collaborations. Fastest reply is email.
        </p>
      </div>

      <div class="relative grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {cards.map((c) => {
          const Tag = c.href ? 'a' : 'div';
          return (
            <Tag
              href={c.href}
              target={c.href?.startsWith('http') || c.href?.endsWith('.pdf') ? '_blank' : undefined}
              rel={c.href?.startsWith('http') ? 'noopener' : undefined}
              class="card-glow spotlight card-hover p-5 text-center block"
            >
              <div class="w-10 h-10 mx-auto rounded-lg bg-brand/10 text-brand border border-brand/30 flex items-center justify-center mb-3">
                {c.icon === 'loc' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                )}
                {c.icon === 'mail' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                )}
                {c.icon === 'phone' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                )}
                {c.icon === 'file' && (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                )}
              </div>
              <div class="text-[10px] uppercase tracking-wider text-ink-500 font-mono mb-1">{c.label}</div>
              <div class="text-sm text-white break-words">{c.value}</div>
            </Tag>
          );
        })}
      </div>

      <div class="relative mt-10 flex flex-wrap justify-center items-center gap-3">
        <a href="mailto:bhikadi@uwindsor.ca" data-magnetic class="btn btn-primary transition-transform duration-200">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          Email Me
        </a>
        <a href="https://www.linkedin.com/in/pratikbhikadiya/" target="_blank" rel="noopener" data-magnetic class="btn btn-ghost transition-transform duration-200">
          LinkedIn
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
